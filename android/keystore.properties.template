# Keystore Configuration for Cosmic Ocean Android App
# Copy this file to keystore.properties and fill in your values
# NEVER commit keystore.properties to version control!

# Path to your keystore file (relative to android/ folder)
storeFile=keystore/release.jks

# Keystore password
storePassword=your-keystore-password

# Key alias
keyAlias=cosmic-ocean-key

# Key password
keyPassword=your-key-password
