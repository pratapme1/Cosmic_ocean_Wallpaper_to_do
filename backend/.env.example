# Cosmic Ocean Backend - Environment Variables
# Copy this file to .env and fill in your values

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:6543/database?sslmode=require

# Redis Cache (Upstash)
REDIS_URL=redis://default:password@host:port

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Gemini LLM (Epic 8: Intelligence Enhancement)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Model Configuration
# Options: gemini-2.0-flash-lite, gemini-1.5-flash-latest, gemini-1.5-flash, gemini-pro
# Default: gemini-2.0-flash-lite (fastest, cheapest)
GEMINI_MODEL=gemini-2.0-flash-lite

# Feature Flags (Epic 8)
ENABLE_LLM_PARSING=true   # Enable/disable LLM parsing globally
ENABLE_LLM_MESSAGES=true  # Enable/disable LLM message generation

# Server Configuration
NODE_ENV=development      # development | production | test
PORT=3000                 # Server port (default: 3000)

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=info           # error | warn | info | debug

# Rate Limiting (default values)
RATE_LIMIT_LLM_MINUTE=10    # LLM requests per minute per user
RATE_LIMIT_LLM_DAY=100      # LLM requests per day per user

# API Configuration
API_VERSION=1.2.1
