# Cosmic Ocean Backend - Environment Variables
# Copy this file to .env and fill in your values

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:6543/database?sslmode=require

# Redis Cache (Upstash)
REDIS_URL=redis://default:password@host:port

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Claude LLM (Epic 8: Intelligence Enhancement)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Claude Model Configuration
# Options: claude-3-haiku-20240307, claude-3-sonnet-20240229, claude-3-5-sonnet-20241022, claude-3-opus-20240229
# Default: claude-3-haiku-20240307 (fastest, cheapest)
CLAUDE_MODEL=claude-3-haiku-20240307

# Feature Flags (Epic 8)
ENABLE_LLM_PARSING=true   # Enable/disable LLM parsing globally
ENABLE_LLM_MESSAGES=true  # Enable/disable LLM message generation

# Server Configuration
NODE_ENV=development      # development | production | test
PORT=3000                 # Server port (default: 3000)

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=info           # error | warn | info | debug

# Rate Limiting (default values)
RATE_LIMIT_LLM_MINUTE=10    # LLM requests per minute per user
RATE_LIMIT_LLM_DAY=100      # LLM requests per day per user

# API Configuration
API_VERSION=1.2.1
